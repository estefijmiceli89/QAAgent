# Jira Configuration (shared)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=CCAI

# Jira user configuration (BUG creator)
# These are optional but recommended so the script can assign and mention correctly.
ASSIGNEE_ACCOUNT_ID=paolo_account_id_here
REPORTER_ACCOUNT_ID=estefania_account_id_here
REPORTER_DISPLAY_NAME=estefania miceli

# Custom field configuration (BUG creator)
# CCAI Product must be set to "Q-AI". Put here the custom field id for that field,
# e.g., customfield_12345, and the script will always send value "Q-AI".
CCAI_PRODUCT_FIELD_ID=customfield_XXXXX

# Claude API Configuration (test case generator)
CLAUDE_API_KEY=your_claude_api_key_here

# Google Drive Configuration (test case generator)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here
